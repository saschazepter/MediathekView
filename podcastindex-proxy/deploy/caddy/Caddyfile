# Beispiel für einen Reverse Proxy vor dem lokalen Podcastindex-Proxy.
# Der Go-Dienst sollte dazu auf 127.0.0.1:18080 lauschen.

podcastindex.example.org {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}

	@health path /health
	handle @health {
		reverse_proxy 127.0.0.1:18080 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	@podcastSearch path /api/audiothek/podcast-search
	handle @podcastSearch {
		reverse_proxy 127.0.0.1:18080 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle {
		respond "Not Found" 404
	}

	log {
		output file /var/log/caddy/podcastindex-proxy-access.log
		format json
	}
}
